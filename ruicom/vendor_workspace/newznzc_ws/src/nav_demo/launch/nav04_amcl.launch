<launch>
  <!-- ruikang/managed_vendor_bundle external workspace wrapper -->
  <arg name="namespace" default="" />
  <arg name="scan_topic" default="scan" />
  <arg name="odom_topic" default="odom" />
  <arg name="base_frame" default="base_footprint" />
  <arg name="odom_frame" default="odom" />
  <arg name="global_frame" default="map" />
  <group ns="$(arg namespace)">
    <node pkg="amcl" type="amcl" name="amcl" output="screen" clear_params="true">
      <param name="odom_frame_id" value="$(arg odom_frame)" />
      <param name="base_frame_id" value="$(arg base_frame)" />
      <param name="global_frame_id" value="$(arg global_frame)" />
      <remap from="scan" to="$(arg scan_topic)" />
      <remap from="odom" to="$(arg odom_topic)" />
      <rosparam command="load" file="$(find nav_demo)/param/amcl_params.yaml" />
    </node>
  </group>
</launch>
