<launch>
  <arg name="namespace" default="" />
  <arg name="output_root" default="/tmp/ruikang_recon_baseline_integration" />

  <group ns="$(arg namespace)">
    <node pkg="ruikang_recon_baseline" type="fake_move_base_action_server.py" name="fake_move_base_action_server" output="screen">
      <param name="action_name" value="move_base" />
      <param name="pose_topic" value="amcl_pose" />
      <param name="goal_completion_delay_sec" value="0.25" />
      <param name="pose_publish_delay_sec" value="0.05" />
      <param name="publish_initial_pose" value="true" />
      <param name="initial_pose_publish_hz" value="10.0" />
      <param name="stop_initial_pose_after_first_goal" value="true" />
    </node>
  </group>

  <include file="$(find ruikang_recon_baseline)/launch/core.launch">
    <arg name="namespace" value="$(arg namespace)" />
    <arg name="enable_synthetic" value="true" />
    <arg name="enable_vision" value="true" />
    <arg name="enable_mission" value="true" />
    <arg name="enable_recorder" value="true" />
    <arg name="enable_safety" value="false" />
    <arg name="profile_synthetic_config" value="$(find ruikang_recon_baseline)/config/profiles/baseline_integration/synthetic.yaml" />
    <arg name="profile_vision_config" value="$(find ruikang_recon_baseline)/config/profiles/baseline_integration/vision.yaml" />
    <arg name="profile_mission_config" value="$(find ruikang_recon_baseline)/config/profiles/baseline_integration/mission.yaml" />
    <arg name="profile_recorder_config" value="$(find ruikang_recon_baseline)/config/profiles/baseline_integration/recorder.yaml" />
    <arg name="profile_safety_config" value="$(find ruikang_recon_baseline)/config/profiles/baseline_integration/safety.yaml" />
    <arg name="output_root" value="$(arg output_root)" />
  </include>

  <test test-name="baseline_integration_smoke" pkg="ruikang_recon_baseline" type="baseline_integration_smoke.py" time-limit="45.0">
    <param name="namespace" value="$(arg namespace)" />
    <param name="output_root" value="$(arg output_root)" />
    <param name="output_root_use_namespace" value="true" />
    <param name="expected_route_total" value="4" />
    <param name="expected_detector_type" value="color_blob" />
    <param name="mission_state_typed_topic" value="recon/mission_state_typed" />
    <param name="zone_capture_dynamic_topic" value="recon/zone_capture_result_dynamic" />
    <param name="summary_snapshot_dynamic_topic" value="recon/summary_snapshot_v2" />
    <param name="detections_topic" value="recon/detections" />
    <rosparam param="expected_class_names">[friendly, enemy, hostage]</rosparam>
    <rosparam param="expected_zone_counts">
      zone_a: {friendly: 2, enemy: 1, hostage: 1}
      zone_b: {friendly: 1, enemy: 3, hostage: 1}
      zone_c: {friendly: 0, enemy: 2, hostage: 2}
      zone_d: {friendly: 3, enemy: 0, hostage: 1}
    </rosparam>
  </test>
</launch>
