<launch>
  <arg name="namespace" default="" />
  <arg name="camera_topic" default="camera/rgb/image_raw" />
  <group ns="$(arg namespace)">
    <node pkg="ruikang_recon_baseline" type="managed_scene_image_publisher.py" name="managed_scene_image_publisher" output="screen">
      <param name="camera_topic" value="/$(arg namespace)/$(arg camera_topic)" />
      <param name="publish_rate_hz" value="8.0" />
    </node>
  </group>
</launch>
