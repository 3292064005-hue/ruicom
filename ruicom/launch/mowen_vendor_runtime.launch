<launch>
  <arg name="namespace" default="" />
  <arg name="vendor_namespace" default="" />
  <arg name="vendor_ns_prefix" default="$(eval '/' + arg('vendor_namespace').strip('/') if arg('vendor_namespace').strip('/') else '')" />
  <arg name="output_root" default="" />
  <arg name="detections_topic" default="" />
  <arg name="camera_topic" default="$(eval arg('vendor_ns_prefix') + '/camera/rgb/image_raw' if arg('vendor_ns_prefix') else '/camera/rgb/image_raw')" />
  <arg name="use_sim_time" default="false" />
  <arg name="field_asset_id" default="" />
  <arg name="field_asset_path" default="" />
  <arg name="field_asset_package_root" default="" />
  <arg name="model_manifest_path" default="" />
  <arg name="vendor_runtime_contract_path" default="$(find ruikang_recon_baseline)/config/vendor_runtime/mowen_mo_sergeant_vendor_contract.yaml" />

  <arg name="vendor_bringup_launch" default="" />
  <arg name="vendor_navigation_launch" default="" />
  <arg name="vendor_camera_launch" default="" />
  <arg name="vendor_lidar_launch" default="" />
  <arg name="vendor_imu_launch" default="" />

  <arg name="enable_vendor_bringup" default="true" />
  <arg name="enable_vendor_navigation" default="true" />
  <arg name="enable_vendor_camera" default="true" />
  <arg name="enable_vendor_lidar" default="true" />
  <arg name="enable_vendor_imu" default="true" />

  <arg name="upstream_feedback_topic" default="$(eval arg('vendor_ns_prefix') + '/recon/platform/vendor/base_feedback_raw')" />
  <arg name="odom_topic" default="$(eval arg('vendor_ns_prefix') + '/odom' if arg('vendor_ns_prefix') else 'odom')" />
  <arg name="amcl_pose_topic" default="$(eval arg('vendor_ns_prefix') + '/amcl_pose' if arg('vendor_ns_prefix') else 'amcl_pose')" />
  <arg name="move_base_action_name" default="$(eval arg('vendor_ns_prefix') + '/move_base' if arg('vendor_ns_prefix') else 'move_base')" />
  <arg name="upstream_odom_topic" default="$(eval arg('vendor_ns_prefix') + '/odom')" />
  <arg name="upstream_control_mode_topic" default="" />
  <arg name="upstream_estop_topic" default="" />
  <arg name="upstream_navigation_status_topic" default="$(eval arg('vendor_ns_prefix') + '/move_base/status')" />
  <arg name="upstream_command_topic" default="$(eval arg('vendor_ns_prefix') + '/cmd_vel' if arg('vendor_ns_prefix') else 'recon/platform/vendor/cmd_vel')" />

  <group ns="$(arg vendor_namespace)">
    <include if="$(eval arg('enable_vendor_bringup') and arg('vendor_bringup_launch') != '')" file="$(arg vendor_bringup_launch)" />
    <include if="$(eval arg('enable_vendor_navigation') and arg('vendor_navigation_launch') != '')" file="$(arg vendor_navigation_launch)" />
    <include if="$(eval arg('enable_vendor_camera') and arg('vendor_camera_launch') != '')" file="$(arg vendor_camera_launch)" />
    <include if="$(eval arg('enable_vendor_lidar') and arg('vendor_lidar_launch') != '')" file="$(arg vendor_lidar_launch)" />
    <include if="$(eval arg('enable_vendor_imu') and arg('vendor_imu_launch') != '')" file="$(arg vendor_imu_launch)" />
  </group>

  <include file="$(find ruikang_recon_baseline)/launch/reference_field_deploy.launch">
    <arg name="namespace" value="$(arg namespace)" />
    <arg name="output_root" value="$(arg output_root)" />
    <arg name="camera_topic" value="$(arg camera_topic)" />
    <arg name="detections_topic" value="$(arg detections_topic)" />
    <arg name="odom_topic" value="$(arg odom_topic)" />
    <arg name="amcl_pose_topic" value="$(arg amcl_pose_topic)" />
    <arg name="move_base_action_name" value="$(arg move_base_action_name)" />
    <arg name="field_asset_id" value="$(arg field_asset_id)" />
    <arg name="field_asset_path" value="$(arg field_asset_path)" />
    <arg name="field_asset_package_root" value="$(arg field_asset_package_root)" />
    <arg name="use_sim_time" value="$(arg use_sim_time)" />
    <arg name="model_manifest_path" value="$(arg model_manifest_path)" />
    <arg name="vendor_runtime_contract_path" value="$(arg vendor_runtime_contract_path)" />
    <arg name="upstream_feedback_topic" value="$(arg upstream_feedback_topic)" />
    <arg name="upstream_odom_topic" value="$(arg upstream_odom_topic)" />
    <arg name="upstream_control_mode_topic" value="$(arg upstream_control_mode_topic)" />
    <arg name="upstream_estop_topic" value="$(arg upstream_estop_topic)" />
    <arg name="upstream_navigation_status_topic" value="$(arg upstream_navigation_status_topic)" />
    <arg name="upstream_command_topic" value="$(arg upstream_command_topic)" />
    <arg name="enable_platform_bridge" value="true" />
  </include>
</launch>
